# JS Clawhub 环境变量
# 复制此文件为 .env 并根据实际需要修改

# Cloudflare API 认证（二选一）：
# 方式 1：API Token（推荐）- 在 https://dash.cloudflare.com/profile/api-tokens 创建，需 Zone:Read, Zone:Edit, DNS:Edit 权限
CLOUDFLARE_API_TOKEN=<YOUR_CLOUDFLARE_API_TOKEN>
# 方式 2：若使用 Global API Key，需额外配置邮箱
# CLOUDFARE_API_KEY=<YOUR_CLOUDFARE_API_KEY>
# CLOUDFLARE_EMAIL=<YOUR_CLOUDFARE_EMAIL>

# GitHub API 认证（用于自动配置 Pages 自定义域名）
# 创建：https://github.com/settings/tokens ，需 repo 权限
GITHUB_TOKEN=<YOUR_GITHUB_TOKEN>

# AI 翻译 API（用于 blog-translate 命令）
# 兼容 OpenAI API 的服务地址
CLAWHUB_API_BASE_URL=http://localhost:8888/v1
# API Key（本地模型可用 not-needed）
CLAWHUB_API_KEY=not-needed
# 模型名称
CLAWHUB_API_MODEL=default

# Google Analytics ID
GA_ID=<YOUR_GA_ID>
